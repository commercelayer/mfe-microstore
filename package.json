{
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r check:fix",
    "test": "pnpm -r test",
    "test:e2e": "pnpm -r test:e2e",
    "clean": "pnpm dlx rimraf --glob **/node_modules **/pnpm-lock.yaml",
    "dep:upgrade:major": "pnpm -r exec npm-check-updates -u",
    "dep:upgrade:minor": "pnpm dep:upgrade:major -t minor"
  },
  "keywords": [],
  "author": {
    "name": "Matteo Alessani",
    "email": "matteo@commercelayer.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commercelayer/monorepo-starter.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "pnpm": ">=7"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "lerna": "^9.0.7",
    "npm-check-updates": "^19.6.6"
  },
  "resolutions": {
    "tar": ">=7.5.10"
  }
}
